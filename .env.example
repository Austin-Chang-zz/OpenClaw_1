# ─────────────────────────────────────────────────────────────────────────────
# OpenClaw – Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────────────────

# PostgreSQL connection string (auto-set on Replit; set manually for Docker)
DATABASE_URL=postgresql://user:password@localhost:5432/openclaw

# Redis connection string (required from Epic 2 onwards for the task queue)
REDIS_URL=redis://localhost:6379/0

# Application secret key — MUST be a long random string in production
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here-change-in-production

# ── AI Providers (optional — leave blank to disable) ──────────────────────────

# OpenAI GPT-4 / Whisper
OPENAI_API_KEY=

# Anthropic Claude
ANTHROPIC_API_KEY=

# DeepSeek — cost-effective Chinese LLM (alternative to OpenAI)
DEEPSEEK_API_KEY=

# MiniMax — cost-effective TTS + video generation (Chinese provider)
MINIMAX_API_KEY=

# ── Optional overrides ────────────────────────────────────────────────────────

# Set to "true" to enable FastAPI debug mode (auto-reload, verbose errors)
# DEBUG=false
